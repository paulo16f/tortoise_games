# Depthbreaker client (Vite) — BUILD-TIME env (baked into the bundle).
# On Railway set these as service variables so the Dockerfile ARGs pick them up.

# Backend REST base URL (Fastify). Local dev default: http://localhost:3000
VITE_BACKEND_URL=https://backend-xxxx.up.railway.app

# Realtime WebSocket URL (Colyseus). Local dev default: ws://localhost:2567
VITE_REALTIME_URL=wss://realtime-xxxx.up.railway.app
