{
  "name": "depthbreaker",
  "version": "0.1.0",
  "private": true,
  "description": "Depthbreaker — web 3D multiplayer roguelike. npm workspace: shared sim + protocol, Fastify backend, Colyseus realtime server, React Three Fiber client.",
  "workspaces": [
    "packages/*",
    "backend",
    "realtime",
    "client"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:backend": "npm run dev --workspace backend",
    "dev:realtime": "npm run dev --workspace realtime",
    "dev:client": "npm run dev --workspace client"
  }
}
