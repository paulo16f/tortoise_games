{
  "name": "@depthbreaker/sim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic game math (RNG, combat, XP, threat, loot, dungeon) shared across backend, realtime server, and client.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:vectors": "tsx src/generateVectors.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
