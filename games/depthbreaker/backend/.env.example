# Depthbreaker backend — copy to .env (or export) and adjust.
# Missing values fall back to DEV DEFAULTS that /api/health rejects in production.

NODE_ENV=development
PORT=3100

DATABASE_URL=postgres://depthbreaker:depthbreaker@localhost:5432/depthbreaker

# HS256 secret for access-token JWTs. Generate: openssl rand -base64 48
SESSION_SECRET=

# Shared secret between backend and Unity zone servers (join tickets +
# /internal/* auth). Generate separately from SESSION_SECRET.
ZONE_SHARED_SECRET=

# URL the browser client connects to for realtime (the Colyseus server).
# Plain ws://localhost:2667 for local dev; wss:// behind a proxy in prod.
ZONE_WS_URL=ws://localhost:2667

# Origin allowed to make credentialed API calls (the page serving the WebGL build).
CORS_ORIGIN=http://localhost:5184

# Token lifetimes (seconds). Defaults: access 900, guest refresh 30d, email 7d.
#ACCESS_TOKEN_TTL_SECONDS=900
#REFRESH_TTL_GUEST_SECONDS=2592000
#REFRESH_TTL_EMAIL_SECONDS=604800
#JOIN_TICKET_TTL_SECONDS=60

# Integration tests only: vitest runs DB-backed suites when this is set.
#TEST_DATABASE_URL=postgres://depthbreaker:depthbreaker@localhost:5432/depthbreaker_test

# --- Solana devnet (gold-exchange buy leg) ---
# ALL FOUR + the flag must be set or /api/goldmarket/buy stays 503 (fail closed).
# Generate devnet values with: node tools/setup_devnet.mjs setup
SOLANA_RPC_URL=https://api.devnet.solana.com
TOKEN_MINT=
TREASURY_WALLET=
# Fixed USD per token for devnet quotes (mainnet swaps this for an oracle).
TOKEN_USD_PRICE=0.01
GOLD_MARKET_BUY_ENABLED=false
