    "colyseus": "^0.16.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
