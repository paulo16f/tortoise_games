# Depthbreaker realtime (Colyseus) — copy to .env (or set as Railway variables).

NODE_ENV=development
# Listen port. Railway injects PORT automatically; REALTIME_PORT is the local fallback.
REALTIME_PORT=2667

# MUST match the backend's ZONE_SHARED_SECRET (verifies signed join tickets).
ZONE_SHARED_SECRET=

# Backend base URL for /internal reporting (public URL is fine on Railway).
BACKEND_URL=http://localhost:3100

# Require signed join tickets. Defaults to true when NODE_ENV=production.
# For the initial soft launch the client connects ticketless, so set false in
# prod until the full auth flow (guest login -> runs/start -> ticket) is wired.
REQUIRE_TICKET=false
